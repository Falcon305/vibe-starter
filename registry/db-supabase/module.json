{
  "name": "db-supabase",
  "title": "Supabase database",
  "description": "Hosted Postgres and typed access through the Supabase client, with SSR cookie handling",
  "category": "data",
  "version": "0.1.0",
  "provides": ["db"],
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@supabase/ssr": "^0.12.0"
  },
  "env": [
    {
      "key": "NEXT_PUBLIC_SUPABASE_URL",
      "required": true,
      "secret": false,
      "description": "Your Supabase project URL",
      "example": ""
    },
    {
      "key": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
      "required": true,
      "secret": false,
      "description": "Your Supabase anon key",
      "example": ""
    }
  ],
  "csp": {
    "scriptSrc": [],
    "connectSrc": ["https://*.supabase.co"],
    "imgSrc": [],
    "frameSrc": []
  },
  "postInstall": [
    "Set NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY in .env.local",
    "Import createClient from @/lib/supabase/server in server code, or @/lib/supabase/client in the browser"
  ],
  "legal": {
    "subprocessors": [
      { "name": "Supabase", "purpose": "Database hosting", "url": "https://supabase.com/privacy" }
    ],
    "cookies": [],
    "dataCollected": ["Whatever you store in your Supabase tables"]
  }
}
